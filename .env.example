# .env.example — copy to .env and fill in your values.
# .env is gitignored — never commit the actual .env file.

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# VITE_ prefix required — these are embedded in the client bundle at build time.

# Admin UID — the Firebase Auth UID that can access the /admin dashboard.
# Find yours in the Firebase console → Authentication → Users.
VITE_ADMIN_UID=your-firebase-uid-here

# ── Scripts ───────────────────────────────────────────────────────────────────
# cantonese.ai API key — used by scripts/download-audio.py and download-audio.sh
# Get yours at https://cantonese.ai/account
CANTONESE_AI_API_KEY=sk-your-key-here

# ── Cloudflare Worker secrets ─────────────────────────────────────────────────
# Set these with: wrangler secret put SECRET_NAME
# (Not used in Vite frontend — Worker reads them at runtime)

# CANTONESE_AI_KEY=sk-your-cantonese-ai-key
# ANTHROPIC_KEY=sk-ant-your-anthropic-key
# ELEVENLABS_KEY=your-elevenlabs-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# Stripe (web payments)
# STRIPE_SECRET_KEY=sk_live_...          — Stripe secret key
# STRIPE_PRICE_MONTHLY=price_...         — £9.99/month product
# STRIPE_PRICE_ANNUAL=price_...          — £54.99/year product (7-day trial)
# STRIPE_PRICE_LIFETIME=price_...        — £149 one-time product
# STRIPE_PRICE_FAMILY=price_...          — £79.99/year family product
