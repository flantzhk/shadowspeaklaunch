  "dialogueScenes": [
    {
      "id": "ynm-scene-1",
      "title": "Declining an invitation politely",
      "description": "A colleague invites you to dinner but you're busy",
      "turns": [
        {
          "speaker": "other",
          "speakerLabel": "Colleague",
          "phraseId": null,
          "chinese": "今晚一齊食飯？",
          "jyutping": "gam1 maan5 jat1 cai4 sik6 faan6?",
          "romanization": "Gam¹ maan⁵ jat¹ cai⁴ sik⁶ faan⁶?",
          "english": "Dinner together tonight?",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 2000
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "ynm-006",
          "chinese": "唔得呀，今晚有嘢做。",
          "jyutping": "m4 dak1 aa3, gam1 maan5 jau5 je5 zou6.",
          "romanization": "M⁴ dak¹ aa³, gam¹ maan⁵ jau⁵ je⁵ zou⁶.",
          "english": "Can't tonight, I'm busy.",
          "voiceId": null,
          "pauseAfterMs": 2000
        },
        {
          "speaker": "other",
          "speakerLabel": "Colleague",
          "phraseId": null,
          "chinese": "聽日呢？",
          "jyutping": "ting1 jat6 ne1?",
          "romanization": "Ting¹ jat⁶ ne¹?",
          "english": "How about tomorrow?",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1500
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "ynm-001",
          "chinese": "好呀，冇問題！",
          "jyutping": "hou2 aa3, mou5 man6 tai4!",
          "romanization": "Hou² aa³, mou⁵ man⁶ tai⁴!",
          "english": "Sure, no problem!",
          "voiceId": null,
          "pauseAfterMs": 1500
        },
        {
          "speaker": "other",
          "speakerLabel": "Colleague",
          "phraseId": null,
          "chinese": "好，聽日見！",
          "jyutping": "hou2, ting1 jat6 gin3!",
          "romanization": "Hou², ting¹ jat⁶ gin³!",
          "english": "Great, see you tomorrow!",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1000
        }
      ]
    },
    {
      "id": "ynm-scene-2",
      "title": "Checking if it's okay to bring a friend",
      "description": "You want to bring someone extra to a gathering",
      "turns": [
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "qq-017",
          "chinese": "我帶多個朋友，得唔得？",
          "jyutping": "ngo5 daai3 do1 go3 pang4 jau5, dak1 m4 dak1?",
          "romanization": "Ngo⁵ daai³ do¹ go³ pang⁴ jau⁵, dak¹ m⁴ dak¹?",
          "english": "Can I bring an extra friend along?",
          "voiceId": null,
          "pauseAfterMs": 2000
        },
        {
          "speaker": "other",
          "speakerLabel": "Host",
          "phraseId": null,
          "chinese": "得呀，冇問題。",
          "jyutping": "dak1 aa3, mou5 man6 tai4.",
          "romanization": "Dak¹ aa³, mou⁵ man⁶ tai⁴.",
          "english": "Sure, no problem at all.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1500
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "basics-006",
          "chinese": "多謝晒！",
          "jyutping": "do1 ze6 saai3!",
          "romanization": "Do¹ ze⁶ saai³!",
          "english": "Thank you so much!",
          "voiceId": null,
          "pauseAfterMs": 1000
        },
        {
          "speaker": "other",
          "speakerLabel": "Host",
          "phraseId": null,
          "chinese": "唔使客氣，多人多熱鬧。",
          "jyutping": "m4 sai2 haak3 hei3, do1 jan4 do1 jit6 naau6.",
          "romanization": "M⁴ sai² haak³ hei³, do¹ jan⁴ do¹ jit⁶ naau⁶.",
          "english": "Don't mention it — the more the merrier.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1000
        }
      ]
