        {
          "speaker": "other",
          "speakerLabel": "Neighbor",
          "phraseId": null,
          "chinese": "幾好呀。今日天氣好好。",
          "jyutping": "gei2 hou2 aa3. gam1 jat6 tin1 hei3 hou2 hou2.",
          "romanization": "Gei² hou² aa³. Gam¹ jat⁶ tin¹ hei³ hou² hou².",
          "english": "Pretty good. The weather is lovely today.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 2000
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "basics-010",
          "chinese": "係呀！拜拜！",
          "jyutping": "hai6 aa3! baai1 baai3!",
          "romanization": "Hai⁶ aa³! Baai¹ baai³!",
          "english": "Yes! Bye!",
          "voiceId": null,
          "pauseAfterMs": 1500
        },
        {
          "speaker": "other",
          "speakerLabel": "Neighbor",
          "phraseId": null,
          "chinese": "拜拜！",
          "jyutping": "baai1 baai3!",
          "romanization": "Baai¹ baai³!",
          "english": "Bye!",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1000
        }
      ]
