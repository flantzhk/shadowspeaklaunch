    {
      "id": "qq-scene-1",
      "title": "Finding the bathroom in a restaurant",
      "description": "You need the toilet and ask a member of staff",
      "turns": [
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "basics-002",
          "chinese": "唔該，廁所喺邊度？",
          "jyutping": "m4 goi1, ci3 so2 hai6 bin1 dou6?",
          "romanization": "M⁴ goi¹, chi³ so² hai⁶ bin¹ dou⁶?",
          "english": "Excuse me, where's the toilet?",
          "voiceId": null,
          "pauseAfterMs": 2000
        },
        {
          "speaker": "other",
          "speakerLabel": "Staff",
          "phraseId": null,
          "chinese": "直行，轉左。",
          "jyutping": "zik6 haang4, zyun3 zo2.",
          "romanization": "Zik⁶ haang⁴, zyun³ zo².",
          "english": "Go straight, then turn left.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 2000
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "basics-006",
          "chinese": "多謝！",
          "jyutping": "do1 ze6!",
          "romanization": "Do¹ ze⁶!",
          "english": "Thank you!",
          "voiceId": null,
          "pauseAfterMs": 1000
        },
        {
          "speaker": "other",
          "speakerLabel": "Staff",
          "phraseId": null,
          "chinese": "唔使客氣。",
          "jyutping": "m4 sai2 haak3 hei3.",
          "romanization": "M⁴ sai² haak³ hei³.",
          "english": "You're welcome.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1000
        }
      ]
    },
