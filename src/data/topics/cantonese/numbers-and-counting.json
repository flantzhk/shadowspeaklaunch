          "phraseId": null,
          "chinese": "好，我WhatsApp你。",
          "jyutping": "hou2, ngo5 WhatsApp nei5.",
          "romanization": "Hou², ngo⁵ WhatsApp nei⁵.",
          "english": "Great, I'll WhatsApp you.",
