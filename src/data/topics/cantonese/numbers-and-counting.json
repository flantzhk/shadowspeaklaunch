  "dialogueScenes": [
    {
      "id": "nums-scene-1",
      "title": "Asking the price at a market stall",
      "description": "You're at a wet market and want to buy some fruit",
      "turns": [
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "nums-011",
          "chinese": "唔該，呢個幾多錢？",
          "jyutping": "m4 goi1, ni1 go3 gei2 do1 cin2?",
          "romanization": "M⁴ goi¹, ni¹ go³ gei² do¹ cin²?",
          "english": "Excuse me, how much is this?",
          "voiceId": null,
          "pauseAfterMs": 2000
        },
        {
          "speaker": "other",
          "speakerLabel": "Vendor",
          "phraseId": null,
          "chinese": "三十蚊。",
          "jyutping": "saam1 sap6 man1.",
          "romanization": "Saam¹ sap⁶ man¹.",
          "english": "Thirty dollars.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1500
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "nums-012",
          "chinese": "太貴喇！平啲得唔得？",
          "jyutping": "taai3 gwai3 laa3! peng4 di1 dak1 m4 dak1?",
          "romanization": "Taai³ gwai³ laa³! Peng⁴ di¹ dak¹ m⁴ dak¹?",
          "english": "Too expensive! Can you go a bit cheaper?",
          "voiceId": null,
          "pauseAfterMs": 2000
        },
        {
          "speaker": "other",
          "speakerLabel": "Vendor",
          "phraseId": null,
          "chinese": "廿五蚊啦，最平喇。",
          "jyutping": "jaa6 ng5 man1 laa3, zeoi3 peng4 laa3.",
          "romanization": "Jaa⁶ ng⁵ man¹ laa³, zeoi³ peng⁴ laa³.",
          "english": "Twenty-five dollars, that's the lowest.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 2000
        },
        {
          "speaker": "user",
          "speakerLabel": "You",
          "phraseId": "nums-014",
          "chinese": "好，我要兩個。",
          "jyutping": "hou2, ngo5 jiu3 loeng5 go3.",
          "romanization": "Hou², ngo⁵ jiu³ loeng⁵ go³.",
          "english": "Okay, I'll take two.",
          "voiceId": null,
          "pauseAfterMs": 1500
        },
        {
          "speaker": "other",
          "speakerLabel": "Vendor",
          "phraseId": null,
          "chinese": "好，五十蚊，多謝。",
          "jyutping": "hou2, ng5 sap6 man1, do1 ze6.",
          "romanization": "Hou², ng⁵ sap⁶ man¹, do¹ ze⁶.",
          "english": "Great, fifty dollars, thank you.",
          "voiceId": "99fb84cf-d081-4df6-8b8a-7165015a2f5d",
          "pauseAfterMs": 1000
        }
      ]
    },
