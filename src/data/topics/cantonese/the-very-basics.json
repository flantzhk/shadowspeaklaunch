            "pauseAfterMs": 2000
          },
          {
            "speaker": "user",
            "speakerLabel": "You",
            "phraseId": "basics-010",
            "chinese": "係呀！拜拜！",
            "jyutping": "hai6 aa3! baai1 baai3!",
            "romanization": "Hai⁶ aa³! Baai¹ baai³!",
            "english": "Yes! Bye!",
            "voiceId": null,
            "pauseAfterMs": 1500
